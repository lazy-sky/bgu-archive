# 앱 (브라우저에 노출됨)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 프로덕션에서 권장: https://your-deployment.vercel.app 또는 커스텀 도메인 (끝에 / 없음).
# OG·절대 URL + OAuth redirect 일치용. Supabase Redirect URLs에도 동일 origin의 /auth/callback 을 등록할 것.
# NEXT_PUBLIC_SITE_URL=

# (선택) 후원 페이지: 카카오페이 송금 QR의 https://qr.kakaopay.com/... 주소(금액 없는 기본 링크).
# 금액은 코드에서 경로에 붙이므로, 미리 금액이 박힌 링크는 넣지 마세요.
# NEXT_PUBLIC_DONATE_KAKAO_URL=

# 시드 스크립트 전용 (서버/CI에서만, 절대 클라이언트에 넣지 말 것)
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 로컬에서 scripts/apply-migration.mjs 실행 시만
# Supabase → Settings → Database → Database password
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=
