# 앱 (브라우저에 노출됨)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (선택) OG·절대 URL용. 커스텀 도메인이면 https://your-domain.com 형태로 (Vercel 기본 도메인은 VERCEL_URL로도 동작)
# NEXT_PUBLIC_SITE_URL=

# 시드 스크립트 전용 (서버/CI에서만, 절대 클라이언트에 넣지 말 것)
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 로컬에서 scripts/apply-migration.mjs 실행 시만
# Supabase → Settings → Database → Database password
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=
